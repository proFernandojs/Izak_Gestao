# Porta do servidor
PORT=3000

# CORS - Origins permitidas (separadas por vírgula)
ORIGINS=

# Provider de boletos (PAGBANK ou MOCK)
PROVIDER=MOCK

# Dados opcionais para PagBank
PAGBANK_TOKEN=
PAGBANK_SECRET=

# Endereço fallback do pagador para PagBank
PAGADOR_STREET=
PAGADOR_NUMBER=
PAGADOR_DISTRICT=
PAGADOR_CITY=
